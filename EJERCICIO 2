
def calcular_descuento(precio, descuento=10):
    precio_final = precio - (precio * (descuento / 100))
    return precio_final

def ejecutar_ejercicio_2():
    total_pagar = 0
    print("\n--- Registro de Ventas ---")
    
    for i in range(1, 4):
        try:
            p = float(input(f"Ingrese el precio del producto {i}: "))
            
            total_pagar += calcular_descuento(p)
        except ValueError:
            print("Precio no válido, se saltará este producto.")
            
    print(f"El valor total a pagar (con descuento aplicado) es: {total_pagar}")

ejecutar_ejercicio_2()
