def ejercicio_1():
    print("--- Buscador de Números Primos ---")
    try:
        limite = int(input("Ingrese un número entero positivo: "))
        
        if limite < 2:
            print("No hay números primos menores a 2.")
            return

        primos = []
        
        for num in range(2, limite + 1):
            es_primo = True
            
            for i in range(2, int(num**0.5) + 1):
                if num % i == 0:
                    es_primo = False
                    break
            
            if es_primo:
                primos.append(num)
        
        print(f"Primos encontrados: {primos}")
        print(f"Cantidad total: {len(primos)}")
        
    except ValueError:
        print("Error: Ingrese un número entero válido.")

ejercicio_1()
